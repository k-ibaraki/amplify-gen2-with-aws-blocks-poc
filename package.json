{
  "name": "amplify-gen2-with-aws-blocks-poc",
  "version": "1.0.0",
  "description": "PoC: AWS Blocks のコードを Amplify Gen2 のデプロイに一元化する",
  "type": "module",
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "concurrently \"npm:back\" \"npm:front\"",
    "front": "vite",
    "back": "tsx watch aws-blocks/scripts/server.ts",
    "front:amplify": "tsx aws-blocks/scripts/use-amplify-backend.ts && vite",
    "deploy:amplify": "NODE_OPTIONS=--conditions=cdk ampx sandbox",
    "deploy:amplify:once": "NODE_OPTIONS=--conditions=cdk ampx sandbox --once",
    "destroy:amplify": "ampx sandbox delete",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k-ibaraki/amplify-gen2-with-aws-blocks-poc.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "aws-cdk-lib": "2.257.0",
    "concurrently": "^8.2.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.76"
  }
}
