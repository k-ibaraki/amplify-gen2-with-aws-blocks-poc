    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "aws-amplify": "^6.18.0"
